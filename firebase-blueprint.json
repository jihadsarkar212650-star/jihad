{
  "entities": {
    "AppSettings": {
      "title": "Application Settings",
      "description": "Global settings for the application including notice and support team info",
      "type": "object",
      "properties": {
        "notice": {
          "type": "array",
          "description": "List of current notices for students"
        },
        "supportTeam": {
          "type": "array",
          "description": "Support team contact information"
        },
        "systemActive": {
          "type": "boolean",
          "description": "Whether the system is currently active"
        }
      }
    },
    "Student": {
      "title": "Student",
      "description": "Student profile and account data",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Pending", "Block"] }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Store items available for purchase",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "price": { "type": "string" },
        "img": { "type": "string" }
      }
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Student success stories and photos",
      "type": "object",
      "properties": {
        "studentName": { "type": "string" },
        "message": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentName", "message", "status", "createdAt"]
    }
  },
  "firestore": {
    "/settings/global": {
      "schema": "AppSettings",
      "description": "Global application configuration"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Individual student data"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store products"
    },
    "/testimonials/{testimonialId}": {
      "schema": "Testimonial",
      "description": "Student success stories and photos"
    }
  }
}
