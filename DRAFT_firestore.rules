rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // For now, allow the specific admin user ID if we had auth set up
      // Since we are using manual login for now, this is just a draft
      return isSignedIn() && request.auth.token.email == 'admin@unityearning.com';
    }

    match /settings/global {
      allow read: if true; // Everyone can read global settings like Notice
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isSignedIn() && (request.auth.uid == studentId || isAdmin());
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
